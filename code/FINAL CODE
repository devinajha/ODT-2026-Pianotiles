from ble_keyboard import BLEKeyboard
from machine import Pin, TouchPad
import struct
import time

kb = BLEKeyboard("ESP32")

# Touch pins
touch_f = TouchPad(Pin(15))
touch_g = TouchPad(Pin(13))
touch_h = TouchPad(Pin(12))
touch_j = TouchPad(Pin(14))

# Key mappings
KEY_F = 0x09
KEY_G = 0x0A
KEY_H = 0x0B
KEY_J = 0x0D

keys = {
    'f': KEY_F,
    'g': KEY_G,
    'h': KEY_H,
    'j': KEY_J,
}

touch_pads = {
    'f': touch_f,
    'g': touch_g,
    'h': touch_h,
    'j': touch_j,
}

# State tracking
held = {k: False for k in keys}
last_touch_time = {k: 0 for k in keys}

# Tunable parameters (STABLE VALUES)
TOUCH_THRESHOLD = 20
RELEASE_THRESHOLD = 10
DEBOUNCE_MS = 200

# ---------- Helper Functions ----------

def calibrate(touch, samples=50):
    total = 0
    for _ in range(samples):
        total += touch.read()
        time.sleep_ms(10)
    return total // samples

def smooth_read(touch, samples=10):
    return sum(touch.read() for _ in range(samples)) // samples

def send_keys(active_keys):
    keycodes = [0] * 6
    i = 0
    for k in active_keys:
        if i < 6:
            keycodes[i] = keys[k]
            i += 1
    kb._send(struct.pack("8B", 0, 0, *keycodes))

# ---------- Calibration ----------

print("Calibrating... Do NOT touch sensors")
baseline = {k: calibrate(touch_pads[k]) for k in touch_pads}
print("Baseline values:", baseline)

print("Waiting for Bluetooth connection...")
connection_ready = False

# ---------- Main Loop ----------

while True:
    if kb.is_connected():
        if not connection_ready:
            print("Connected! Stabilizing...")
            time.sleep(2)
            print("Ready!")
            connection_ready = True

        try:
            now = time.ticks_ms()
            active_keys = []

            for k in touch_pads:
                val = smooth_read(touch_pads[k])
                delta = baseline[k] - val

                # hysteresis logic
                if not held[k]:
                    touched = delta > TOUCH_THRESHOLD
                else:
                    touched = delta > RELEASE_THRESHOLD

                # debounce + state tracking
                if touched and not held[k]:
                    if time.ticks_diff(now, last_touch_time[k]) > DEBOUNCE_MS:
                        print(f"{k.upper()} DOWN")
                        held[k] = True
                        last_touch_time[k] = now

                elif not touched and held[k]:
                    print(f"{k.upper()} UP")
                    held[k] = False
                    last_touch_time[k] = now

                if held[k]:
                    active_keys.append(k)

            # send all active keys together
            send_keys(active_keys)

            # slow baseline drift correction (only when untouched)
            if not any(held.values()):
                for k in baseline:
                    baseline[k] = int(0.99 * baseline[k] + 0.01 * smooth_read(touch_pads[k]))

        except ValueError:
            pass

    else:
        held = {k: False for k in held}
        connection_ready = False

    time.sleep_ms(20)
